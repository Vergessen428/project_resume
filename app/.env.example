OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Optional model failover. Leave any provider you do not use blank.
# A request moves to the next configured provider only when the preceding API fails.
MODEL_FALLBACK_ORDER=gemini,openai,deepseek,openrouter,custom

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Use this for any other OpenAI-compatible endpoint, such as a self-hosted model.
CUSTOM_MODEL_API_KEY=
CUSTOM_MODEL_NAME=
CUSTOM_MODEL_BASE_URL=
